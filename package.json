{
  "name": "@andrew24601/reckon",
  "version": "0.1.2",
  "description": "Incremental Node.js build graph runner",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "engines": {
    "node": ">=20"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "keywords": [
    "build",
    "incremental",
    "task-runner",
    "node",
    "typescript"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "node --input-type=module -e \"import { rm } from 'node:fs/promises'; await rm('dist', { recursive: true, force: true });\" && tsc -p tsconfig.build.json",
    "check": "tsc --noEmit -p tsconfig.json",
    "test": "node --import tsx --test test/**/*.test.ts",
    "prepack": "npm run build",
    "prepublishOnly": "npm run check && npm test",
    "pack:dry-run": "npm pack --dry-run",
    "release:check": "npm run check && npm test && npm run build && npm pack --dry-run"
  },
  "devDependencies": {
    "@types/node": "^22.15.18",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3"
  }
}
